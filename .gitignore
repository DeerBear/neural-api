# The DelphiCL OpenCL binding is vendored as a git submodule for the
# standalone Delphi port; keep it tracked despite the bare 'opencl' rule.
!delphi/opencl
!delphi/opencl/**

# Build artifacts
bin/
*.o
*.ppu
*.exe
*.compiled
*.bak
backup/
lib/

# Python bytecode cache (from delphi/_port_tool.py used during the port)
__pycache__/
*.pyc
*.bin
*.identcache
*.nn
*.txt
*.dcu
*.rsm
